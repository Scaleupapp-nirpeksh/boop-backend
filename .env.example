# Server
PORT=3000
NODE_ENV=development
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/boop

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_TEMPLATE_NAMESPACE=your_template_namespace

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=boop-uploads

# Firebase (push notifications)
FIREBASE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----\n"

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# OTP Config
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_SECONDS=60
OTP_LENGTH=6

# Dev mode - logs OTP to console instead of sending SMS
DEV_SKIP_TWILIO=true
